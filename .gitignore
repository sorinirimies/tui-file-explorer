*.log
*.tmp
*.temp
tmp/
temp/

# =============================================================================
# Persistence — sled embedded databases
#
# sled::open("path/name.db") creates a *directory*, not a single file.
# Guard against any accidental local DB directories in the repo tree.
# The real DBs live in the OS config dir (~/.config/flashkraft/) so they
# will never appear here in normal use, but this catches test accidents.
# =============================================================================
*.db/
**/*.db/

# =============================================================================
# VHS / demo recordings
# =============================================================================

# Raw VHS tape sources and generated GIFs are tracked:
#   *.tape  → plain text, committed directly
#   *.gif   → binary, stored via Git LFS (see .gitattributes)
#
# Guard against VHS writing anything else into the working tree:
*.vhs/
.vhs/

# =============================================================================
# Project-specific
# =============================================================================

# Leftover swap file from a previous editing session in this repo
.is.swp
